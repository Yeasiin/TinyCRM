PORT=4000
BETTER_AUTH_URL=http://localhost:4000
BETTER_AUTH_SECRET=change-me-to-a-random-secret

# Comma-separated list of trusted frontend origins for Better Auth.
# Express CORS is set to reflect any origin dynamically (origin: true).
# Better Auth still requires explicit trustedOrigins for CSRF protection.
# Example: http://localhost:3000,https://tiny-crm-frontend.vercel.app,https://tinycrm-v1.vercel.app
FRONTEND_URL=http://localhost:3000

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
