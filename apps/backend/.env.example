PORT=4000
BETTER_AUTH_URL=http://localhost:4000
BETTER_AUTH_SECRET=change-me-to-a-random-secret

# REQUIRED: Comma-separated list of trusted frontend origins for Better Auth.
# This is used for BOTH Better Auth trustedOrigins AND CORS validation.
# You MUST include every domain your frontend runs on, including production and local dev.
#
# Examples:
#   Production only:   FRONTEND_URL=https://tinycrm-v1.vercel.app
#   With local dev:    FRONTEND_URL=http://localhost:3000,https://tinycrm-v1.vercel.app
#
# If this is missing or wrong, sign-in will fail with 403 Forbidden.
FRONTEND_URL=http://localhost:3000

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
